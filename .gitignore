# Exclude all files and folders in databases/ except for example_tree.json
databases/*
!databases/example_tree.json

# Cache file
.db_cache.json

# Python temporary files
__pycache__/
scratch/
*.py[cod]
*$py.class

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# PyInstaller build output
build/
dist/
*.spec

# App-generated local data/backups
archive_versions/
trees/
*_required_properties.txt
